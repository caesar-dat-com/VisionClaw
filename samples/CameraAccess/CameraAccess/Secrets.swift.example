import Foundation

enum Secrets {
    // Gemini API key — NOT required when using AresLiveService (Ares mode)
    // Leave empty or add your own key if you want to switch back to Gemini
    static let geminiAPIKey = ""

    // REQUIRED: OpenClaw / Ares gateway config
    // Tailscale IP of ares-home: 100.111.183.96
    static let openClawHost = "http://100.111.183.96"
    static let openClawPort = 18889
    static let openClawHookToken = "YOUR_OPENCLAW_HOOK_TOKEN"
    static let openClawGatewayToken = "YOUR_OPENCLAW_GATEWAY_TOKEN"

    // OPTIONAL: WebRTC signaling server
    static let webrtcSignalingURL = ""
}
